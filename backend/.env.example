APP_NAME=AI Dataset Explorer API
ENV=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SECRET_KEY=replace_with_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
MAX_UPLOAD_MB=50

DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ai_studio_db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_DATASETS=datasets
S3_BUCKET_ARTIFACTS=artifacts

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=SuperAdmin123!